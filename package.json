{
  "name": "marez-cafe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "kill-port": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true",
    "kill-ports": "for p in 3000 3333; do lsof -ti :$p | xargs kill -9 2>/dev/null || true; done",
    "predev": "npm run kill-ports",
    "dev": "next dev --hostname 127.0.0.1 --webpack -p 3000",
    "build": "next build",
    "serve": "next start --hostname 127.0.0.1 -p 3000",
    "site": "bash scripts/start-site.sh 3333",
    "start:local": "npm run kill-port && npm run build && npm run serve",
    "start": "next start",
    "lint": "eslint",
    "set-shakshuka": "node scripts/set-shakshuka-image.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
